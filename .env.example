# Flask Application Configuration
# Copy this file to .env and fill in the actual values

# Flask Settings
FLASK_APP = "src.enrgdocdb.app:create_app()"
FLASK_SECRET_KEY = "your-secret-key-here"

# Database Configuration
DATABASE_URL = "mysql+pymysql://username:password@127.0.0.1:3306/enrgdocdb"

# Upload Settings
FILE_UPLOAD_FOLDER = "./uploads"

# Security Settings
FLASK_SECURITY_PASSWORD_SALT = "your-random-salt-string-here"
FLASK_SECURITY_DEFAULT_REMEMBER_ME = "true"

# TOTP Secret (for Two-Factor Authentication)
TOTP_SECRET = "your-base32-encoded-totp-secret-here"

# OAuth Settings
FLASK_SECURITY_REGISTERABLE = "true"
FLASK_SECURITY_OAUTH_ENABLE = "true"
FLASK_SECURITY_OAUTH_ENABLE_SLACK = "true"
FLASK_SLACK_CLIENT_ID = "your-slack-client-id"
FLASK_SLACK_CLIENT_SECRET = "your-slack-client-secret"

# LDAP Configuration
LLDAP_URL = "http://127.0.0.1:17170"
LLDAP_ADMIN_PASSWORD = "your-ldap-admin-password"
